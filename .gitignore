/target
*.axil
models/
.env
# Benchmark crate sources are tracked. Per-benchmark generated/heavy
# artefacts are not — dataset downloads (data/), Cargo target dirs,
# transient `out/` runs from gate scripts, raw `.out` console captures,
# and Cargo.lock for the workspace-excluded harnesses.
/benchmarks/**/data/
/benchmarks/**/target/
/benchmarks/**/out/
/benchmarks/**/*.out
/benchmarks/**/Cargo.lock
.axil/
docs/book/
.claude-octopus/
# Local workspace federation manifest — contains machine-specific absolute
# paths and private-sibling references; never shipped publicly.
.axil-workspace.toml
.axil-workspace.local.toml
# Claude Code tooling — maintainer-local, regenerated by `axil install`.
# The shipped source templates live in crates/adapters/axil-cli/src/. Never published.
.claude/

# context A/B experiment sandboxes (cloned repos + indexes)
experiments/

# Internal phase/planning docs — kept locally + in Axil memory, not shipped in
# the public repo. Atlas/commercial planning docs live in the private axil-atlas repo.
tasks/

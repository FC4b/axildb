# Copy to `.env` (same dir as docker-compose.yml) and fill in. Docker Compose
# auto-loads `.env` and substitutes these into the stack.
#
# REQUIRED for semantic/hybrid search AND for ingestion in every mode: AMS
# embeds each memory at ingest and embeds queries for semantic/hybrid search
# using EMBEDDING_MODEL (default OpenAI text-embedding-3-small).
OPENAI_API_KEY=

# --- Optional overrides (documented defaults live in docker-compose.yml) ---
# REDIS_AGENT_MEMORY_VERSION=0.15.2
# REDIS_VERSION=7.4.0-v8
# EMBEDDING_MODEL=text-embedding-3-small
# REDISVL_VECTOR_DIMENSIONS=1536

# --- Extraction: leave False for the no-LLM retrieval baseline ---
# Set these True (and provide the relevant key) ONLY for a separate,
# clearly-labeled extraction-ON run.
# ENABLE_DISCRETE_MEMORY_EXTRACTION=False
# ENABLE_TOPIC_EXTRACTION=False
# ENABLE_NER=False
# GENERATION_MODEL=gpt-4o-mini
